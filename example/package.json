{
  "name": "example",
  "type": "module",
  "scripts": {
    "build:ps": "cd .. && spago build -p example --output example/output",
    "build:wasm": "cd .. && node ./bin/index.dev.js build -e Example.Main -I ./example/output -O ./example/output-wasm",
    "build": "pnpm run build:ps && pnpm run build:wasm",
    "exec": "node ./run.mjs",
    "check": "purs-tidy check src"
  }
}